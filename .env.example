# Copy this file to .env and fill in your values if you want to override defaults.
# .env is gitignored — never commit it.
#
# GCP credentials:
#   Download your service account JSON key from:
#   GCP Console → IAM & Admin → Service Accounts → [your account] → Keys → Add Key
#   Save it as gcp-key.json in the project root (it is gitignored).
#
# Then run: docker compose up

# GCP resource identifiers (defaults match docker-compose.yml)
GCP_PROJECT=scouting-466001
GCS_BUCKET=magician-scouting-project
BQ_DATASET=scouting
